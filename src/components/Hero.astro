---
import Icon from './Icon.astro';
import { formatDateParts } from '../lib/dates';

export interface Artist { name: string; }
export interface EventEntry {
  data: {
    title: string;
    date: Date;
    time: string;
    doorsOpen: string;
    venue: string;
    address: string;
    headliner?: string;
    artists: Artist[];
    note?: string;
  };
}

export interface Props {
  nextEvent?: EventEntry;
  eyebrow: string;
  intro: string;
}

const { nextEvent, eyebrow, intro } = Astro.props;
const d = nextEvent ? formatDateParts(nextEvent.data.date) : null;
const year = d?.year ?? new Date().getFullYear();
const eyebrowDisplay = eyebrow.startsWith('✶') ? eyebrow : `✶ ${eyebrow} ✶`;
---

<section class="relative grit section-ink overflow-hidden">
  <div class="micro absolute" style="top: 1.5rem; left: 1.25rem; color: var(--bone-3);">
    VOL. III · ISSUE Nº {year}
  </div>
  <div class="micro absolute hidden sm:block" style="top: 1.5rem; right: 1.25rem; color: var(--bone-3);">
    WRITERS NIGHT · ALL SEATS FREE
  </div>

  <div class="container relative z-10" style="padding-top: 5rem; padding-bottom: 4rem;">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
      <div class="lg:col-span-7 rise">
        <div class="micro uppercase" style="color: var(--ember); letter-spacing: 0.18em;">
          {eyebrowDisplay}
        </div>

        <h1 class="font-slab mt-6" style="line-height: 0.85;">
          <span style="display: block; font-size: clamp(4.5rem, 14vw, 12rem); color: var(--bone);">2ND</span>
          <span style="display: block; font-size: clamp(4.5rem, 14vw, 12rem); margin-top: -0.5rem; color: var(--ember);">
            SAT<span style="color: var(--bone);">.</span>
          </span>
        </h1>

        <div class="font-slab mt-3" style="font-size: clamp(1.4rem, 3vw, 2.4rem); color: var(--bone);">
          SONGWRITERS<span style="color: var(--ember);"> · </span>IN<span style="color: var(--ember);"> · </span>THE<span style="color: var(--ember);"> · </span>ROUND
        </div>

        <div class="mt-8 double-rule" style="color: var(--bone);"></div>

        <p class="font-serif italic mt-7 leading-snug" style="font-size: 1.4rem; max-width: 36rem; color: var(--bone-2); white-space: pre-line;">
          {intro}
        </p>

        <div class="mt-9 flex flex-wrap gap-3 items-center">
          <a href="/events" class="btn btn-ember">
            See the calendar <Icon name="arrowRight" size={14} />
          </a>
          <a href="/visit" class="btn btn-bone">
            How to find us
          </a>
        </div>
      </div>

      {nextEvent && d && (
        <div class="lg:col-span-5 rise" style="animation-delay: 0.18s;">
          <div
            class="relative p-7 sm:p-9"
            style="background: var(--paper); color: var(--ink); box-shadow: 10px 10px 0 var(--ember);"
          >
            <div class="absolute micro" style="top: 0.75rem; right: 0.75rem; color: var(--ember-deep);">
              Nº {d.year}-{String(d.day).padStart(2, '0')}
            </div>

            <div class="micro" style="color: var(--ember-deep);">NEXT ROUND</div>

            <div class="mt-4 flex items-end gap-5">
              <div class="text-center">
                <div class="font-condensed font-bold tracking-widest" style="font-size: 0.875rem; color: var(--ember-deep);">
                  {d.month}
                </div>
                <div class="font-slab" style="font-size: 5rem; line-height: 0.85;">
                  {d.day}
                </div>
                <div class="micro" style="color: var(--ink-3);">
                  {d.weekday}.
                </div>
              </div>

              <div class="pb-2 flex-1">
                <div class="font-slab text-xl leading-tight">
                  DOORS<br/>
                  <span style="color: var(--ember-deep);">{nextEvent.data.doorsOpen}</span>
                </div>
                <div class="font-slab text-xl mt-2 leading-tight">
                  MUSIC<br/>
                  <span style="color: var(--ember-deep);">{nextEvent.data.time}</span>
                </div>
              </div>
            </div>

            <div class="my-6 rule-ink"></div>

            {nextEvent.data.headliner && (
              <div class="mb-5">
                <div class="font-condensed font-bold uppercase" style="font-size: 0.75rem; letter-spacing: 0.22em; color: var(--ember-deep);">
                  ★ Headliner
                </div>
                <div class="font-slab leading-tight mt-1" style="font-size: 2rem;">
                  {nextEvent.data.headliner}
                </div>
              </div>
            )}

            {nextEvent.data.artists.length > 0 && (
              <>
                <div class="font-condensed font-bold uppercase" style="font-size: 1rem; letter-spacing: 0.18em;">
                  {nextEvent.data.headliner ? 'And in the Line' : 'In the Round'}
                </div>
                <ul class="mt-3" style="list-style: none; padding: 0; margin: 0;">
                  {nextEvent.data.artists.map(artist => (
                    <li class="font-slab leading-tight" style="font-size: 1.4rem;">
                      {artist.name}
                    </li>
                  ))}
                </ul>
              </>
            )}

            <div class="my-6 rule-ink" style="opacity: 0.3;"></div>

            <div class="flex items-start gap-2 font-mono text-xs leading-relaxed">
              <Icon name="mapPin" size={12} class="shrink-0" />
              <div>
                <div class="font-condensed font-bold uppercase text-sm tracking-wider">
                  {nextEvent.data.venue}
                </div>
                <div class="mt-1" style="color: var(--ink-3);">{nextEvent.data.address}</div>
              </div>
            </div>

            <div class="mt-5 stamp" style="color: var(--ember-deep);">
              No Cover · All Ages
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
