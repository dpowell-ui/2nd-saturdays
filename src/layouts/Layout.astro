---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'A monthly Christian music songwriters round in Spring Hill, Tennessee. Hosted on the 2nd Saturday of every month at Just Love Coffee Cafe.',
  ogImage = '/photos/duo-stage.jpg',
} = Astro.props;

const currentPath = Astro.url.pathname;
const fullTitle = title === '2nd Saturdays' ? title : `${title} · 2nd Saturdays`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Nav currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Netlify Identity widget for the /admin route -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
  </body>
</html>
