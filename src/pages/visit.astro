---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const schedule = [
  { time: '5:30 PM', what: 'Doors // Food & Coffee' },
  { time: '6:00 PM', what: 'Round Begins' },
  { time: '8:30 PM', what: 'Music Wraps' },
];
---

<Layout
  title="Visit"
  description="How to find 2nd Saturdays at Just Love Coffee Cafe in Spring Hill, Tennessee. Free parking, no cover, all ages welcome."
>
  <section class="relative grit section-ink">
    <div class="container py-16 sm:py-24 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-5">
          <div class="micro" style="color: var(--ember);">How to Visit</div>
          <h1 class="font-slab mt-5" style="font-size: clamp(3.5rem, 10vw, 7.5rem); line-height: 0.85;">
            FIND<br/>
            <span style="color: var(--ember);">US.</span>
          </h1>

          <div class="mt-10 double-rule" style="color: var(--bone);"></div>

          <div class="mt-10 space-y-9">
            <div>
              <div class="eyebrow flex items-center gap-2" style="color: var(--ember);">
                <Icon name="mapPin" size={12} /> The Address
              </div>
              <div class="font-slab mt-3 leading-tight" style="font-size: 1.875rem;">JUST LOVE</div>
              <div class="font-slab leading-tight" style="font-size: 1.875rem; margin-top: -0.25rem;">COFFEE CAFE</div>
              <div class="font-mono text-sm mt-3" style="color: var(--bone-2);">
                4816 MAIN STREET<br/>
                SPRING HILL, TN 37174
              </div>
              <a
                href="https://maps.google.com/?q=4816+Main+Street+Spring+Hill+TN+37174"
                target="_blank"
                rel="noreferrer"
                class="font-condensed font-bold uppercase underline-grow inline-flex items-center gap-2 mt-4"
                style="font-size: 0.875rem; letter-spacing: 0.16em; color: var(--ember);"
              >
                Open in Maps <Icon name="arrowUpRight" size={13} />
              </a>
            </div>

            <div>
              <div class="eyebrow flex items-center gap-2" style="color: var(--ember);">
                <Icon name="clock" size={12} /> The Schedule
              </div>
              <div class="mt-3 space-y-2 font-condensed">
                {schedule.map(({ time, what }) => (
                  <div class="flex items-center gap-4">
                    <span class="font-slab" style="font-size: 1.125rem; width: 6rem; color: var(--bone);">{time}</span>
                    <span class="uppercase tracking-wider text-sm" style="color: var(--bone-2);">{what}</span>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <div class="eyebrow flex items-center gap-2" style="color: var(--ember);">
                <Icon name="phone" size={12} /> Questions
              </div>
              <a
                href="mailto:hello@2ndsaturdays.org"
                class="font-mono text-sm underline-grow mt-3"
                style="color: var(--bone); display: inline-block;"
              >
                hello@2ndsaturdays.org
              </a>
            </div>

            <div class="pt-2">
              <div class="stamp" style="color: var(--ember);">
                No Cover · All Ages
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div
            class="relative overflow-hidden"
            style="background: var(--ink-3); border: 2px solid var(--bone); box-shadow: 10px 10px 0 var(--ember); aspect-ratio: 4 / 3;"
          >
            <iframe
              title="Map to Just Love Coffee Cafe Spring Hill"
              width="100%"
              height="100%"
              loading="lazy"
              src="https://maps.google.com/maps?q=4816+Main+Street+Spring+Hill+TN+37174&output=embed"
              style="border: 0; filter: invert(0.92) hue-rotate(180deg) saturate(0.4) contrast(0.95);"
            ></iframe>
          </div>
          <p class="font-mono text-xs mt-4 uppercase tracking-wider" style="color: var(--bone-3);">
            ⛬ Free parking in the lot beside the cafe and along Main Street.
          </p>

          <figure class="mt-10">
            <div
              class="relative overflow-hidden"
              style="border: 2px solid var(--bone); aspect-ratio: 16 / 11;"
            >
              <img
                src="/photos/group-small.jpg"
                alt="After a round at Just Love Coffee Cafe — writers and listeners."
                class="object-cover"
                loading="lazy"
              />
            </div>
            <figcaption class="mt-3 micro flex items-center gap-2" style="color: var(--bone-3);">
              <span class="star" style="color: var(--ember);"></span>
              A round wraps. Writers + listeners, hanging on after the last song.
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>
</Layout>
