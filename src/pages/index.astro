---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import FromTheRoom from '../components/FromTheRoom.astro';
import WhatIs from '../components/WhatIs.astro';
import UpcomingRounds from '../components/UpcomingRounds.astro';
import HomeCTA from '../components/HomeCTA.astro';
import { isUpcoming, sortByDateAsc } from '../lib/dates';

const allEvents = await getCollection('events');
const upcoming = allEvents
  .filter(e => isUpcoming(e.data.date))
  .sort(sortByDateAsc);
const nextEvent = upcoming[0];

const homepage = await getEntry('settings', 'homepage');
const { hero, marquee, format } = homepage.data;
---

<Layout title="2nd Saturdays">
  <Hero nextEvent={nextEvent} eyebrow={hero.eyebrow} intro={hero.intro} />
  <Marquee items={marquee.items} />
  <FromTheRoom />
  <WhatIs eyebrow={format.eyebrow} headline={format.headline} body={format.body} />
  <UpcomingRounds events={upcoming} />
  <HomeCTA />
</Layout>
